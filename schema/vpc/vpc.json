{
  "service": "vpc",
  "module": "vpc",
  "apis": [
    {
      "name": "CreateVpc",
      "method": "POST",
      "uri": "/v{version}/vpc",
      "desc_key": "vpc.CreateVpc.desc",
      "parameters": [
        {"name": "version",     "type": "String",  "required": false, "position": "URL",   "default": "1", "desc_key": "common.version"},
        {"name": "clientToken", "type": "String",  "required": false, "position": "QUERY", "desc_key": "vpc.CreateVpc.clientToken"},
        {"name": "name",        "type": "String",  "required": true,  "position": "BODY",  "desc_key": "vpc.CreateVpc.name"},
        {"name": "description", "type": "String",  "required": false, "position": "BODY",  "desc_key": "vpc.CreateVpc.description"},
        {"name": "cidr",        "type": "String",  "required": true,  "position": "BODY",  "desc_key": "vpc.CreateVpc.cidr"},
        {"name": "enableIpv6",  "type": "Boolean", "required": false, "position": "BODY",  "desc_key": "vpc.CreateVpc.enableIpv6"},
        {
          "name": "tags", "type": "List", "required": false, "position": "BODY", "desc_key": "vpc.CreateVpc.tags",
          "sub_parameters": [
            {"name": "tagKey",   "type": "String", "required": true,  "desc_key": "vpc.CreateVpc.tags.tagKey"},
            {"name": "tagValue", "type": "String", "required": false, "desc_key": "vpc.CreateVpc.tags.tagValue"}
          ]
        }
      ]
    },
    {
      "name": "DescribeVpcs",
      "method": "GET",
      "uri": "/v{version}/vpc",
      "desc_key": "vpc.DescribeVpcs.desc",
      "parameters": [
        {"name": "version",   "type": "String",  "required": false, "position": "URL",   "default": "1", "desc_key": "common.version"},
        {"name": "marker",    "type": "String",  "required": false, "position": "QUERY", "desc_key": "vpc.DescribeVpcs.marker"},
        {"name": "maxKeys",   "type": "Integer", "required": false, "position": "QUERY", "desc_key": "vpc.DescribeVpcs.maxKeys"},
        {"name": "isDefault", "type": "Boolean", "required": false, "position": "QUERY", "desc_key": "vpc.DescribeVpcs.isDefault"},
        {"name": "vpcIds",    "type": "String",  "required": false, "position": "QUERY", "desc_key": "vpc.DescribeVpcs.vpcIds"}
      ]
    },
    {
      "name": "DescribeVpc",
      "method": "GET",
      "uri": "/v{version}/vpc/{vpcId}",
      "desc_key": "vpc.DescribeVpc.desc",
      "parameters": [
        {"name": "version", "type": "String", "required": false, "position": "URL", "default": "1", "desc_key": "common.version"},
        {"name": "vpcId",   "type": "String", "required": true,  "position": "URL", "desc_key": "vpc.DescribeVpc.vpcId"}
      ]
    },
    {
      "name": "UpdateVpc",
      "method": "PUT",
      "uri": "/v{version}/vpc/{vpcId}?modifyAttribute",
      "desc_key": "vpc.UpdateVpc.desc",
      "parameters": [
        {"name": "version",       "type": "String",  "required": false, "position": "URL",   "default": "1", "desc_key": "common.version"},
        {"name": "vpcId",         "type": "String",  "required": true,  "position": "URL",   "desc_key": "vpc.UpdateVpc.vpcId"},
        {"name": "clientToken",   "type": "String",  "required": false, "position": "QUERY", "desc_key": "vpc.UpdateVpc.clientToken"},
        {"name": "name",          "type": "String",  "required": true,  "position": "BODY",  "desc_key": "vpc.UpdateVpc.name"},
        {"name": "description",   "type": "String",  "required": false, "position": "BODY",  "desc_key": "vpc.UpdateVpc.description"},
        {"name": "enableIpv6",    "type": "Boolean", "required": false, "position": "BODY",  "desc_key": "vpc.UpdateVpc.enableIpv6"},
        {"name": "secondaryCidr", "type": "List",    "required": false, "position": "BODY",  "desc_key": "vpc.UpdateVpc.secondaryCidr"}
      ]
    },
    {
      "name": "DeleteVpc",
      "method": "DELETE",
      "uri": "/v{version}/vpc/{vpcId}",
      "desc_key": "vpc.DeleteVpc.desc",
      "parameters": [
        {"name": "version",     "type": "String", "required": false, "position": "URL",   "default": "1", "desc_key": "common.version"},
        {"name": "vpcId",       "type": "String", "required": true,  "position": "URL",   "desc_key": "vpc.DeleteVpc.vpcId"},
        {"name": "clientToken", "type": "String", "required": false, "position": "QUERY", "desc_key": "vpc.DeleteVpc.clientToken"}
      ]
    },
    {
      "name": "DescribeVpcPrivateIps",
      "method": "GET",
      "uri": "/v{version}/vpc/{vpcId}/privateIpAddressInfo",
      "desc_key": "vpc.DescribeVpcPrivateIps.desc",
      "parameters": [
        {"name": "version",            "type": "String", "required": false, "position": "URL",   "default": "1", "desc_key": "common.version"},
        {"name": "vpcId",              "type": "String", "required": true,  "position": "URL",   "desc_key": "vpc.DescribeVpcPrivateIps.vpcId"},
        {"name": "privateIpAddresses", "type": "String", "required": false, "position": "QUERY", "desc_key": "vpc.DescribeVpcPrivateIps.privateIpAddresses"},
        {"name": "privateIpRange",     "type": "String", "required": false, "position": "QUERY", "desc_key": "vpc.DescribeVpcPrivateIps.privateIpRange"}
      ]
    },
    {
      "name": "DescribeVpcResourceIps",
      "method": "GET",
      "uri": "/v{version}/vpc/resourceIp",
      "desc_key": "vpc.DescribeVpcResourceIps.desc",
      "parameters": [
        {"name": "version",      "type": "String",  "required": false, "position": "URL",   "default": "1", "desc_key": "common.version"},
        {"name": "vpcId",        "type": "String",  "required": true,  "position": "QUERY", "desc_key": "vpc.DescribeVpcResourceIps.vpcId"},
        {"name": "subnetId",     "type": "String",  "required": false, "position": "QUERY", "desc_key": "vpc.DescribeVpcResourceIps.subnetId"},
        {"name": "resourceType", "type": "String",  "required": false, "position": "QUERY", "desc_key": "vpc.DescribeVpcResourceIps.resourceType"},
        {"name": "pageNo",       "type": "Integer", "required": false, "position": "QUERY", "desc_key": "vpc.DescribeVpcResourceIps.pageNo"},
        {"name": "pageSize",     "type": "Integer", "required": false, "position": "QUERY", "desc_key": "vpc.DescribeVpcResourceIps.pageSize"}
      ]
    },
    {
      "name": "EnableVpcRelay",
      "method": "PUT",
      "uri": "/v{version}/vpc/openRelay/{vpcId}",
      "desc_key": "vpc.EnableVpcRelay.desc",
      "parameters": [
        {"name": "version",     "type": "String", "required": false, "position": "URL",   "default": "1", "desc_key": "common.version"},
        {"name": "vpcId",       "type": "String", "required": true,  "position": "URL",   "desc_key": "vpc.EnableVpcRelay.vpcId"},
        {"name": "clientToken", "type": "String", "required": false, "position": "QUERY", "desc_key": "vpc.EnableVpcRelay.clientToken"}
      ]
    },
    {
      "name": "DisableVpcRelay",
      "method": "PUT",
      "uri": "/v{version}/vpc/shutdownRelay/{vpcId}",
      "desc_key": "vpc.DisableVpcRelay.desc",
      "parameters": [
        {"name": "version",     "type": "String", "required": false, "position": "URL",   "default": "1", "desc_key": "common.version"},
        {"name": "vpcId",       "type": "String", "required": true,  "position": "URL",   "desc_key": "vpc.DisableVpcRelay.vpcId"},
        {"name": "clientToken", "type": "String", "required": false, "position": "QUERY", "desc_key": "vpc.DisableVpcRelay.clientToken"}
      ]
    }
  ]
}
