{
  "service": "vpc",
  "module": "subnet",
  "apis": [
    {
      "name": "CreateSubnet",
      "method": "POST",
      "uri": "/v{version}/subnet",
      "desc_key": "vpc.CreateSubnet.desc",
      "parameters": [
        {"name": "version",          "type": "String",  "required": false, "position": "URL",   "default": "1", "desc_key": "common.version"},
        {"name": "clientToken",      "type": "String",  "required": false, "position": "QUERY", "desc_key": "vpc.CreateSubnet.clientToken"},
        {"name": "name",             "type": "String",  "required": true,  "position": "BODY",  "desc_key": "vpc.CreateSubnet.name"},
        {"name": "zoneName",         "type": "String",  "required": true,  "position": "BODY",  "desc_key": "vpc.CreateSubnet.zoneName"},
        {"name": "cidr",             "type": "String",  "required": true,  "position": "BODY",  "desc_key": "vpc.CreateSubnet.cidr"},
        {"name": "vpcId",            "type": "String",  "required": true,  "position": "BODY",  "desc_key": "vpc.CreateSubnet.vpcId"},
        {"name": "enableIpv6",       "type": "Boolean", "required": false, "position": "BODY",  "desc_key": "vpc.CreateSubnet.enableIpv6"},
        {"name": "vpcSecondaryCidr", "type": "String",  "required": false, "position": "BODY",  "desc_key": "vpc.CreateSubnet.vpcSecondaryCidr"},
        {"name": "subnetType",       "type": "String",  "required": false, "position": "BODY",  "desc_key": "vpc.CreateSubnet.subnetType"},
        {"name": "description",      "type": "String",  "required": false, "position": "BODY",  "desc_key": "vpc.CreateSubnet.description"},
        {
          "name": "tags", "type": "List", "required": false, "position": "BODY", "desc_key": "vpc.CreateSubnet.tags",
          "sub_parameters": [
            {"name": "tagKey",   "type": "String", "required": true,  "desc_key": "vpc.CreateSubnet.tags.tagKey"},
            {"name": "tagValue", "type": "String", "required": false, "desc_key": "vpc.CreateSubnet.tags.tagValue"}
          ]
        }
      ]
    },
    {
      "name": "DescribeSubnets",
      "method": "GET",
      "uri": "/v{version}/subnet",
      "desc_key": "vpc.DescribeSubnets.desc",
      "parameters": [
        {"name": "version",    "type": "String",  "required": false, "position": "URL",   "default": "1", "desc_key": "common.version"},
        {"name": "marker",     "type": "String",  "required": false, "position": "QUERY", "desc_key": "vpc.DescribeSubnets.marker"},
        {"name": "maxKeys",    "type": "Integer", "required": false, "position": "QUERY", "desc_key": "vpc.DescribeSubnets.maxKeys"},
        {"name": "vpcId",      "type": "String",  "required": false, "position": "QUERY", "desc_key": "vpc.DescribeSubnets.vpcId"},
        {"name": "zoneName",   "type": "String",  "required": false, "position": "QUERY", "desc_key": "vpc.DescribeSubnets.zoneName"},
        {"name": "subnetType", "type": "String",  "required": false, "position": "QUERY", "desc_key": "vpc.DescribeSubnets.subnetType"},
        {"name": "subnetIds",  "type": "String",  "required": false, "position": "QUERY", "desc_key": "vpc.DescribeSubnets.subnetIds"}
      ]
    },
    {
      "name": "DescribeSubnet",
      "method": "GET",
      "uri": "/v{version}/subnet/{subnetId}",
      "desc_key": "vpc.DescribeSubnet.desc",
      "parameters": [
        {"name": "version",  "type": "String", "required": false, "position": "URL", "default": "1", "desc_key": "common.version"},
        {"name": "subnetId", "type": "String", "required": true,  "position": "URL", "desc_key": "vpc.DescribeSubnet.subnetId"}
      ]
    },
    {
      "name": "UpdateSubnet",
      "method": "PUT",
      "uri": "/v{version}/subnet/{subnetId}?modifyAttribute",
      "desc_key": "vpc.UpdateSubnet.desc",
      "parameters": [
        {"name": "version",     "type": "String",  "required": false, "position": "URL",   "default": "1", "desc_key": "common.version"},
        {"name": "subnetId",    "type": "String",  "required": true,  "position": "URL",   "desc_key": "vpc.UpdateSubnet.subnetId"},
        {"name": "clientToken", "type": "String",  "required": false, "position": "QUERY", "desc_key": "vpc.UpdateSubnet.clientToken"},
        {"name": "name",        "type": "String",  "required": true,  "position": "BODY",  "desc_key": "vpc.UpdateSubnet.name"},
        {"name": "description", "type": "String",  "required": false, "position": "BODY",  "desc_key": "vpc.UpdateSubnet.description"},
        {"name": "enableIpv6",  "type": "Boolean", "required": false, "position": "BODY",  "desc_key": "vpc.UpdateSubnet.enableIpv6"}
      ]
    },
    {
      "name": "DeleteSubnet",
      "method": "DELETE",
      "uri": "/v{version}/subnet/{subnetId}",
      "desc_key": "vpc.DeleteSubnet.desc",
      "parameters": [
        {"name": "version",     "type": "String", "required": false, "position": "URL",   "default": "1", "desc_key": "common.version"},
        {"name": "subnetId",    "type": "String", "required": true,  "position": "URL",   "desc_key": "vpc.DeleteSubnet.subnetId"},
        {"name": "clientToken", "type": "String", "required": false, "position": "QUERY", "desc_key": "vpc.DeleteSubnet.clientToken"}
      ]
    },
    {
      "name": "CreateIpReserve",
      "method": "POST",
      "uri": "/v{version}/subnet/ipreserve",
      "desc_key": "vpc.CreateIpReserve.desc",
      "parameters": [
        {"name": "version",     "type": "String",  "required": false, "position": "URL",   "default": "1", "desc_key": "common.version"},
        {"name": "clientToken", "type": "String",  "required": false, "position": "QUERY", "desc_key": "vpc.CreateIpReserve.clientToken"},
        {"name": "subnetId",    "type": "String",  "required": true,  "position": "BODY",  "desc_key": "vpc.CreateIpReserve.subnetId"},
        {"name": "ipCidr",      "type": "String",  "required": true,  "position": "BODY",  "desc_key": "vpc.CreateIpReserve.ipCidr"},
        {"name": "ipVersion",   "type": "Integer", "required": true,  "position": "BODY",  "desc_key": "vpc.CreateIpReserve.ipVersion"},
        {"name": "description", "type": "String",  "required": false, "position": "BODY",  "desc_key": "vpc.CreateIpReserve.description"}
      ]
    },
    {
      "name": "DescribeIpReserves",
      "method": "GET",
      "uri": "/v{version}/subnet/ipreserve",
      "desc_key": "vpc.DescribeIpReserves.desc",
      "parameters": [
        {"name": "version",  "type": "String",  "required": false, "position": "URL",   "default": "1", "desc_key": "common.version"},
        {"name": "subnetId", "type": "String",  "required": false, "position": "QUERY", "desc_key": "vpc.DescribeIpReserves.subnetId"},
        {"name": "marker",   "type": "String",  "required": false, "position": "QUERY", "desc_key": "vpc.DescribeIpReserves.marker"},
        {"name": "maxKeys",  "type": "Integer", "required": false, "position": "QUERY", "desc_key": "vpc.DescribeIpReserves.maxKeys"}
      ]
    },
    {
      "name": "DeleteIpReserve",
      "method": "DELETE",
      "uri": "/v{version}/subnet/ipreserve/{ipReserveId}",
      "desc_key": "vpc.DeleteIpReserve.desc",
      "parameters": [
        {"name": "version",     "type": "String", "required": false, "position": "URL",   "default": "1", "desc_key": "common.version"},
        {"name": "ipReserveId", "type": "String", "required": true,  "position": "URL",   "desc_key": "vpc.DeleteIpReserve.ipReserveId"},
        {"name": "clientToken", "type": "String", "required": false, "position": "QUERY", "desc_key": "vpc.DeleteIpReserve.clientToken"}
      ]
    }
