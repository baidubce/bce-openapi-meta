{
  "service": "vpc",
  "module": "route",
  "apis": [
    {
      "name": "DescribeRouteTables",
      "method": "GET",
      "uri": "/v{version}/route",
      "desc_key": "vpc.DescribeRouteTables.desc",
      "parameters": [
        {"name": "version",      "type": "String", "required": false, "position": "URL",   "default": "1", "desc_key": "common.version"},
        {"name": "routeTableId", "type": "String", "required": false, "position": "QUERY", "desc_key": "vpc.DescribeRouteTables.routeTableId"},
        {"name": "vpcId",        "type": "String", "required": false, "position": "QUERY", "desc_key": "vpc.DescribeRouteTables.vpcId"}
      ]
    },
    {
      "name": "CreateRouteRule",
      "method": "POST",
      "uri": "/v{version}/route/rule",
      "desc_key": "vpc.CreateRouteRule.desc",
      "parameters": [
        {"name": "version",            "type": "String", "required": false, "position": "URL",   "default": "1", "desc_key": "common.version"},
        {"name": "clientToken",        "type": "String", "required": false, "position": "QUERY", "desc_key": "vpc.CreateRouteRule.clientToken"},
        {"name": "routeTableId",       "type": "String", "required": true,  "position": "BODY",  "desc_key": "vpc.CreateRouteRule.routeTableId"},
        {"name": "sourceAddress",      "type": "String", "required": true,  "position": "BODY",  "desc_key": "vpc.CreateRouteRule.sourceAddress"},
        {"name": "destinationAddress", "type": "String", "required": true,  "position": "BODY",  "desc_key": "vpc.CreateRouteRule.destinationAddress"},
        {"name": "nexthopId",          "type": "String", "required": false, "position": "BODY",  "desc_key": "vpc.CreateRouteRule.nexthopId"},
        {"name": "nexthopType",        "type": "String", "required": false, "position": "BODY",  "desc_key": "vpc.CreateRouteRule.nexthopType"},
        {
          "name": "nextHopList", "type": "List", "required": false, "position": "BODY", "desc_key": "vpc.CreateRouteRule.nextHopList",
          "sub_parameters": [
            {"name": "nexthopId",   "type": "String", "required": true,  "desc_key": "vpc.CreateRouteRule.nextHopList.nexthopId"},
            {"name": "nexthopType", "type": "String", "required": true,  "desc_key": "vpc.CreateRouteRule.nextHopList.nexthopType"},
            {"name": "routeType",   "type": "String", "required": false, "desc_key": "vpc.CreateRouteRule.nextHopList.routeType"}
          ]
        },
        {"name": "description", "type": "String", "required": false, "position": "BODY", "desc_key": "vpc.CreateRouteRule.description"}
      ]
    },
    {
      "name": "DescribeRouteRules",
      "method": "GET",
      "uri": "/v{version}/route/rule",
      "desc_key": "vpc.DescribeRouteRules.desc",
      "parameters": [
        {"name": "version",      "type": "String",  "required": false, "position": "URL",   "default": "1", "desc_key": "common.version"},
        {"name": "routeTableId", "type": "String",  "required": false, "position": "QUERY", "desc_key": "vpc.DescribeRouteRules.routeTableId"},
        {"name": "vpcId",        "type": "String",  "required": false, "position": "QUERY", "desc_key": "vpc.DescribeRouteRules.vpcId"},
        {"name": "marker",       "type": "String",  "required": false, "position": "QUERY", "desc_key": "vpc.DescribeRouteRules.marker"},
        {"name": "maxKeys",      "type": "Integer", "required": false, "position": "QUERY", "desc_key": "vpc.DescribeRouteRules.maxKeys"}
      ]
    },
    {
      "name": "UpdateRouteRule",
      "method": "PUT",
      "uri": "/v{version}/route/rule/{routeRuleId}",
      "desc_key": "vpc.UpdateRouteRule.desc",
      "parameters": [
        {"name": "version",            "type": "String", "required": false, "position": "URL",   "default": "1", "desc_key": "common.version"},
        {"name": "routeRuleId",        "type": "String", "required": true,  "position": "URL",   "desc_key": "vpc.UpdateRouteRule.routeRuleId"},
        {"name": "clientToken",        "type": "String", "required": false, "position": "QUERY", "desc_key": "vpc.UpdateRouteRule.clientToken"},
        {"name": "sourceAddress",      "type": "String", "required": false, "position": "BODY",  "desc_key": "vpc.UpdateRouteRule.sourceAddress"},
        {"name": "destinationAddress", "type": "String", "required": false, "position": "BODY",  "desc_key": "vpc.UpdateRouteRule.destinationAddress"},
        {"name": "nexthopId",          "type": "String", "required": false, "position": "BODY",  "desc_key": "vpc.UpdateRouteRule.nexthopId"},
        {"name": "description",        "type": "String", "required": false, "position": "BODY",  "desc_key": "vpc.UpdateRouteRule.description"}
      ]
    },
    {
      "name": "DeleteRouteRule",
      "method": "DELETE",
      "uri": "/v{version}/route/rule/{routeRuleId}",
      "desc_key": "vpc.DeleteRouteRule.desc",
      "parameters": [
        {"name": "version",     "type": "String", "required": false, "position": "URL",   "default": "1", "desc_key": "common.version"},
        {"name": "routeRuleId", "type": "String", "required": true,  "position": "URL",   "desc_key": "vpc.DeleteRouteRule.routeRuleId"},
        {"name": "clientToken", "type": "String", "required": false, "position": "QUERY", "desc_key": "vpc.DeleteRouteRule.clientToken"}
      ]
    },
    {
      "name": "SwitchRouteHA",
      "method": "PUT",
      "uri": "/v{version}/route/rule/{routeRuleId}?switchRouteHA",
      "desc_key": "vpc.SwitchRouteHA.desc",
      "parameters": [
        {"name": "version",     "type": "String", "required": false, "position": "URL",   "default": "1", "desc_key": "common.version"},
        {"name": "routeRuleId", "type": "String", "required": true,  "position": "URL",   "desc_key": "vpc.SwitchRouteHA.routeRuleId"},
        {"name": "clientToken", "type": "String", "required": false, "position": "QUERY", "desc_key": "vpc.SwitchRouteHA.clientToken"}
      ]
    }
  ]
}
